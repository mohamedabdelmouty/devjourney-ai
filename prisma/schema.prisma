// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  username      String?  @unique
  bio           String?
  avatarUrl     String?
  githubUrl     String?
  linkedinUrl   String?
  portfolioUrl  String?
  xp            Int      @default(0)
  level         Int      @default(1)
  totalDays     Int      @default(0)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastStudyDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  dayProgress     DayProgress[]
  achievements    UserAchievement[]
  certificates    Certificate[]
  projects        Project[]
  jobApplications JobApplication[]
  englishProgress EnglishProgress[]
  notes           Note[]
  quizResults     QuizResult[]

  @@map("users")
}

model DayProgress {
  id          String   @id @default(cuid())
  userId      String
  month       Int      // 1-6
  day         Int      // 1-30
  done        Boolean  @default(false)
  theoryDone  Boolean  @default(false)
  practiceDone Boolean @default(false)
  englishDone Boolean  @default(false)
  quizDone    Boolean  @default(false)
  timeSpent   Int      @default(0) // minutes
  xpEarned    Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, day])
  @@map("day_progress")
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  rarity      String @default("common") // common, rare, epic, legendary
  xpReward    Int    @default(0)
  category    String @default("general") // streak, completion, speed, english, projects

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Certificate {
  id          String   @id @default(cuid())
  userId      String
  month       Int
  title       String
  description String?
  issuedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  difficulty    String   @default("beginner") // beginner, intermediate, advanced
  status        String   @default("not_started") // not_started, in_progress, done
  githubUrl     String?
  liveUrl       String?
  month         Int?
  estimatedTime Int?     // minutes
  topics        String[]
  checklist     Json?    // array of { item: string, done: boolean }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model JobApplication {
  id          String   @id @default(cuid())
  userId      String
  company     String
  role        String
  location    String?
  url         String?
  status      String   @default("applied") // applied, interviewing, offer, rejected, withdrawn
  appliedAt   DateTime @default(now())
  notes       String?
  salary      String?
  contactName String?
  contactEmail String?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

model EnglishProgress {
  id         String   @id @default(cuid())
  userId     String
  category   String   // vocabulary, grammar, listening, speaking, writing, technical, interview
  score      Int      @default(0) // 0-100
  sessionsCompleted Int @default(0)
  lastPracticed DateTime?
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("english_progress")
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  month     Int
  day       Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, day])
  @@map("notes")
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  month     Int
  day       Int
  score     Int      // 0-100
  answers   Json?    // array of { question, answer, correct }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quiz_results")
}
